# Auto detect text files and perform LF normalization
* text=auto

# Specify text/binary files explicitly
*.js text
*.ts text
*.tsx text
*.jsx text
*.css text
*.md text
*.py text
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Image files are binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
