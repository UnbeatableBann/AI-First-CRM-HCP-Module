# Environment variables for Backend

# Database
# For production, change these to strong, randomly generated passwords
POSTGRES_USER=crm_admin_prod
POSTGRES_PASSWORD=generate_a_very_secure_password_here
POSTGRES_DB=crm_db_prod
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# The DATABASE_URL for SQLAlchemy. It must match the credentials above.
# Format: postgresql+asyncpg://<USER>:<PASSWORD>@<SERVER>:<PORT>/<DB>
DATABASE_URL=postgresql+asyncpg://crm_admin_prod:generate_a_very_secure_password_here@db:5432/crm_db_prod

# CORS / Frontend Configuration
# Replace with your actual production frontend URL (e.g., https://your-crm-frontend.vercel.app)
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq
GROQ_API_KEY=your-groq-api-key-here
LLM_MODEL=gemma2-9b-it
LLM_FALLBACK_MODEL=llama-3.3-70b-versatile

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
